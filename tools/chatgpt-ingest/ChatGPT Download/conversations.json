        ],
        "message": {
          "author": {
            "role": "user"
          },
          "create_time": 1717200000,
          "content": {
            "parts": [
              "Give me a simple weeknight roast chicken recipe."
            ]
          }
        }
      },
      "p2": {
        "id": "p2",
        "parent": "p1",
        "children": [
          "p3"
        ],
        "message": {
          "author": {
            "role": "assistant"
          },
          "create_time": 1717200200,
          "content": {
            "parts": [
              "Pat a 4-pound chicken dry. Salt generously. 425 F, 55-65 minutes breast-up until 165 F internal. Rest 10 min. That's it."
            ]
          }
        }
      },
      "p3": {
        "id": "p3",
        "parent": "p2",
        "children": [
          "p4"
        ],
        "message": {
          "author": {
            "role": "user"
          },
          "create_time": 1717200400,
          "content": {
            "parts": [
              "What's a good side — something I don't have to think about?"
            ]
          }
        }
      },
      "p4": {
        "id": "p4",
        "parent": "p3",
        "children": [],
        "message": {
          "author": {
            "role": "assistant"
          },
          "create_time": 1717200600,
          "content": {
            "parts": [
              "Sheet-pan potatoes and onions. Toss halved baby potatoes and quartered onions in olive oil, salt, and rosemary. Put them on the rack under the chicken for the last 40 minutes. The fat drips onto the potatoes."
            ]
          }
        }
      }
    }
